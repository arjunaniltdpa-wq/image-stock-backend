    <a href="/nature.html" class="category active">
      Nature
    </a>

    <a href="/business.html" class="category">
      Business
    </a>

    <a href="/technology.html" class="category">
      Technology
    </a>

    <a href="/travel.html" class="category">
      Travel
    </a>

