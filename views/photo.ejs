</section>

<div class="page-wrapper">

  <main>

    <section class="photo-hero">

      <div class="wallpaper-container">

        <!-- LEFT COLUMN -->
        <div class="photo-left">

          <!-- IMAGE -->
          <div class="image-section">

            <div class="photo-image-wrap">

              <div id="main-skeleton" class="skeleton"></div>

              <img
                id="download-image"
                src="<%= previewUrl %>"
                loading="eager"
                fetchpriority="high"
                width="<%= width %>"
                height="<%= height %>"
                alt="<%= image.alt || title %>"
              />

              <div id="image-protect-overlay"></div>

              <div class="floating-image-actions">

                <button class="floating-icon-btn">❤</button>

                <button
                  class="floating-icon-btn"
                  onclick="downloadImage(window.__originalFileName)"
                >
                  ⤓
                </button>

                <button
                  class="floating-icon-btn openShareModal">
                  ↗
                </button>

              </div>

            </div>

          </div>

          <!-- CONTENT -->
          <div class="under-image-content">

            <h1 class="under-image-title">
              <%= title %>
            </h1>

            <div id="seo-description" class="under-image-desc">

              <div class="seo-content-block">

                <h2>About This Image</h2>

                <div class="main-image-description">
                  <p><%= image.description %></p>
                </div>

                <div class="image-meta-intro">
                  <p>
                    This <strong><%= category %></strong> image has a resolution of
                    <strong><%= width %> × <%= height %></strong>
                    and is available for free download for personal and commercial projects.
                    It can be used in websites, blogs, presentations, digital marketing,
                    social media posts, wallpapers and creative design work.
                  </p>
                </div>

                <% if(caption){ %>

                <div class="image-caption">

                  <h3>Caption</h3>

                  <p><%= caption %></p>

                </div>

                <% } %>

                <% if(useCases && useCases.length){ %>

                <div class="use-case-section">

                  <h3>Recommended Uses</h3>

                  <div class="use-case-grid">

                    <% useCases.forEach(item=>{ %>

                      <span class="use-chip"><%= item %></span>

                    <% }) %>

                  </div>

                  <div class="spec-note">

                    <p>

                      The image is available in its original resolution and can be downloaded
                      for websites, blog articles, social media graphics, presentations,
                      marketing materials, digital designs, wallpapers, print projects and
                      other creative work.

                    </p>

                  </div>

                  <div class="seo-links">

                    <a href="/search.html?query=<%= encodeURIComponent(keywords[0]) %>">
                      Explore <%= keywords[0] %> wallpapers
                    </a>

                    <% if(keywords.length > 1){ %>

                    <a href="/search.html?query=<%= encodeURIComponent(keywords[1]) %>">
                      More <%= keywords[1] %> backgrounds
                    </a>

                    <% } %>

                  </div>

                </div>

                <% } %>

              </div>

            </div>

          </div>

          <% if(keywords && keywords.length){ %>

          <div class="popular-tags">

            <h2>Popular Tags</h2>

            <p>
              Browse related topics and discover more images with similar themes.
            </p>

            <div class="tag-grid">

              <% keywords.slice(0,15).forEach(tag=>{ %>

              <a
                href="/search?q=<%= encodeURIComponent(tag) %>"
                class="tag-chip">

                <%= tag %>

              </a>

              <% }) %>

            </div>

          </div>

          <% } %>

        </div>
        <!-- END photo-left -->


        <!-- RIGHT SIDEBAR -->
        <aside class="photo-sidebar">

          <div class="details-sticky">

            <a
              id="download-link"
              class="download-btn premium-download-btn"
              href="#"
              download="<%= title %>.jpg">

              Free Download

            </a>

            <div class="sidebar-actions">

              <button class="info-btn">Info</button>

              <button class="share-btn openShareModal">
                Share
              </button>

            </div>

            <div class="sidebar-image-details">

              <h3 class="sidebar-title">Image Details</h3>

              <table class="sidebar-details-table">

                <tr>
                  <td>Category</td>
                  <td><%= category %></td>
                </tr>

                <% if(secondaryCategory){ %>

                <tr>
                  <td>Sub Category</td>
                  <td><%= secondaryCategory %></td>
                </tr>

                <% } %>

                <tr>
                  <td>Resolution</td>
                  <td><%= width %> × <%= height %> px</td>
                </tr>

                <tr>
                  <td>Orientation</td>
                  <td><%= image.orientation || (width > height ? "Landscape" : height > width ? "Portrait" : "Square") %></td>
                </tr>

                <tr>
                  <td>Format</td>
                  <td><%= image.format || "JPG" %></td>
                </tr>

                <tr>
                  <td>Quality</td>
                  <td>
                    <% if(width >= 7680 || height >= 4320){ %>
                      8K Ultra HD
                    <% } else if(width >= 3840 || height >= 2160){ %>
                      4K Ultra HD
                    <% } else if(width >= 2560 || height >= 1440){ %>
                      2K QHD
                    <% } else if(width >= 1920 || height >= 1080){ %>
                      Full HD
                    <% } else { %>
                      HD
                    <% } %>
                  </td>
                </tr>

                <tr>
                  <td>File Size</td>
                  <td>
                    <%= image.size ? (image.size/1024/1024).toFixed(2)+" MB" : "-" %>
                  </td>
                </tr>

                <tr>
                  <td>License</td>
                  <td>Free Commercial Use</td>
                </tr>

              </table>

            </div>

            <div class="detail-group">

              <div class="detail-label">Tags</div>

              <div class="detail-tags">

                <% keywords.slice(0,12).forEach(k=>{ %>

                <a href="/search.html?query=<%= encodeURIComponent(k) %>">

                  <%= k %>

                </a>

                <% }) %>

              </div>

            </div>

            <div class="creator-card">

              <div class="creator-avatar">P</div>

              <div class="creator-info">

                <strong>Pixeora Creator</strong>

                <span>Premium Stock Images</span>

              </div>

            </div>

          </div>

        </aside>

      </div>
      <!-- wallpaper-container -->

    </section>

  </main>

</div>


