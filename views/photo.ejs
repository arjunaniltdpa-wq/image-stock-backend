/* =====================================================
   RELATED SYSTEM
===================================================== */

let relatedKeywordList = [];
let relatedKeywordIndex = 0;

let relatedLoading = false;

let relatedPage = 1;

let relatedColIndex = 0;

let relatedImageCounter = 0;

const loadedIds = new Set();

/* =====================================================
   START RELATED
===================================================== */

function startRelatedSystem(
  keywords = [],
  imageData = {}
) {

  relatedKeywordIndex = 0;

  relatedPage = 1;

  relatedLoading = false;

  relatedColIndex = 0;

  relatedImageCounter = 0;

  loadedIds.clear();

  const grid =
  document.querySelector(
    "#related-images"
  );

  if (!grid) return;

  grid.innerHTML = `

    <div class="masonry-col"></div>
    <div class="masonry-col"></div>
    <div class="masonry-col"></div>
    <div class="masonry-col"></div>

  `;

  /* ---------------------------------- */
  /* SKELETONS */
  /* ---------------------------------- */

  for (let i = 0; i < 8; i++) {

    const col =
    grid.children[i % 4];

    col.innerHTML += `
      <div class="related-skeleton"></div>
    `;
  }

  const title =
  (
    imageData.title || ""
  ).toLowerCase();

  const file =
  (
    imageData.fileName || ""
  ).toLowerCase();

  /* ---------------------------------- */
  /* REMOVE JUNK WORDS */
  /* ---------------------------------- */

  const banned = [

    "free",
    "hd",
    "4k",
    "wallpaper",
    "wallpapers",
    "background",
    "backgrounds",
    "image",
    "images",
    "photo",
    "photos",
    "pixeora"

  ];

  const words =

  `${title} ${file}`

  .replace(/[^\w ]+/g, "")

  .split(" ")

  .filter(w =>

    w &&
    w.length > 2 &&
    !banned.includes(w)

  );

  /* ---------------------------------- */
  /* CATEGORY DETECTION */
  /* ---------------------------------- */

  const carWords = [

    "car",
    "cars",
    "hypercar",
    "supercar",
    "bmw",
    "audi",
    "mercedes",
    "porsche",
    "ferrari",
    "lamborghini",
    "mclaren",
    "vehicle"

  ];

  const animeWords = [

    "anime",
    "naruto",
    "dragon",
    "fairy",
    "manga",
    "waifu",
    "demon",
    "natsu",
    "goku"

  ];

  const natureWords = [

    "nature",
    "forest",
    "waterfall",
    "ocean",
    "reef",
    "underwater",
    "flower",
    "bird",
    "mountain"

  ];

  let category = "";

  if (
    words.some(w =>
      carWords.includes(w)
    )
  ) {

    category = "cars";

  }

  else if (
    words.some(w =>
      animeWords.includes(w)
    )
  ) {

    category = "anime";

  }

  else if (
    words.some(w =>
      natureWords.includes(w)
    )
  ) {

    category = "nature";

  }

  /* ---------------------------------- */
  /* VISUAL STYLE */
  /* ---------------------------------- */

  const styleWords = [

    "dark",
    "neon",
    "purple",
    "blue",
    "red",
    "orange",
    "cinematic",
    "fantasy",
    "glow",
    "night"

  ];

  const detectedStyles =

  words.filter(w =>
    styleWords.includes(w)
  );

  /* ---------------------------------- */
  /* STRONGEST TERMS */
  /* ---------------------------------- */

  const exactTheme =
  words.slice(0, 4).join(" ");

  const visualTheme =
  words.slice(0, 2).join(" ");

  const subject =
  keywords[0] || "";

  /* ---------------------------------- */
  /* FINAL PRIORITY */
  /* ---------------------------------- */

  relatedKeywordList = [

    `${category} ${exactTheme}`.trim(),

    `${category} ${visualTheme}`.trim(),

    `${subject} ${detectedStyles.join(" ")}`.trim(),

    `${category} ${subject}`.trim(),

    category,

    exactTheme,

    visualTheme,

    subject,

    ...keywords

  ].filter(Boolean);

  relatedKeywordList =
  [...new Set(relatedKeywordList)];

  loadNextKeywordBatch();
}

/* =====================================================
   LOAD KEYWORD
===================================================== */

async function loadNextKeywordBatch() {

  if (
    relatedKeywordIndex >=
    relatedKeywordList.length
  ) {

    return;
  }

  const keyword =

  relatedKeywordList[
    relatedKeywordIndex++
  ];

  relatedPage = 1;

  let loaded = false;

  while (
    relatedPage <= 4 &&
    !loaded
  ) {

    loaded =
    await loadMoreRelated(
      keyword
    );

    relatedPage++;
  }

  if (!loaded) {

    loadNextKeywordBatch();
  }
}

/* =====================================================
   LOAD RELATED
===================================================== */

async function loadMoreRelated(
  keyword
) {

  if (relatedLoading)
  return true;

  relatedLoading = true;

  try {

    const url =

    `${API_BASE}/api/search?q=${encodeURIComponent(keyword)}&page=${relatedPage}`;

    const res =
    await fetch(url);

    if (!res.ok)
    throw new Error(
      "Search failed"
    );

    const data =
    await res.json();

    let images =
    data.images || [];

    /* ---------------------------------- */
    /* STRICT MATCHING FIRST */
    /* ---------------------------------- */

    if (
      relatedImageCounter < 16
    ) {

      const q =
      keyword.toLowerCase();

      images =

      images.filter(img => {

        const t =
        (
          img.title || ""
        ).toLowerCase();

        return q
        .split(" ")
        .some(w =>
          t.includes(w)
        );

      });
    }

    /* ---------------------------------- */
    /* REMOVE DUPLICATES */
    /* ---------------------------------- */

    const unique =

    images.filter(img => {

      const id =
      img._id || img.id;

      if (!id)
      return false;

      if (
        loadedIds.has(id)
      ) {

        return false;
      }

      loadedIds.add(id);

      return true;

    });

    if (!unique.length) {

      relatedLoading = false;

      return false;
    }

    displayRelated(unique);

    relatedLoading = false;

    return true;

  } catch (err) {

    console.error(
      "RELATED ERROR:",
      err
    );

    relatedLoading = false;

    return false;
  }
}

/* =====================================================
   DISPLAY RELATED
===================================================== */

function displayRelated(
  images = []
) {

  const grid =
  document.querySelector(
    "#related-images"
  );

  if (!grid) return;

  const cols =
  grid.querySelectorAll(
    ".masonry-col"
  );

  document
  .querySelectorAll(
    ".related-skeleton"
  )
  .forEach(el =>
    el.remove()
  );

  images.forEach(img => {

    const col =
    cols[
      relatedColIndex % 4
    ];

    relatedColIndex++;

    relatedImageCounter++;

    const imageUrl =

    img.thumbnailFileName

    ? `https://cdn.pixeora.com/${encodeURIComponent(img.thumbnailFileName)}`

    : img.previewFileName

    ? `https://cdn.pixeora.com/${encodeURIComponent(img.previewFileName)}`

    : img.fileName

    ? `https://cdn.pixeora.com/${encodeURIComponent(img.fileName)}`

    : "";

    if (!imageUrl) return;
    
    const card =
    document.createElement("a");

    card.href =
    `/photo/${img.slug}`;

    card.className =
    "related-card";

    card.innerHTML = `

      <div class="related-image-wrap">

        <img
          src="${imageUrl}"
          alt="${img.title || ''}"
          loading="lazy"
          class="related-image"
          onerror="
            this.onerror=null;
            this.src='https://cdn.pixeora.com/${encodeURIComponent(img.previewFileName || img.fileName || '')}';
          "
        />

        <button class="related-download">

          <img
            src="/images/download-icon.png"
            alt="download"
          />

        </button>

      </div>

    `;

    col.appendChild(card);
  });
}

/* ---------------------------------- */
/* FALLBACK — GUARANTEED CONTENT */
/* ---------------------------------- */
async function loadRelatedFallback() {

  const r = await fetch(`${API_BASE}/api/images/popular-latest?limit=60`);
  const pop = await r.json();
  let images = pop.images || [];

  images = images.sort(() => Math.random() - 0.5);

  displayRelated(images.slice(0, 24));
}

