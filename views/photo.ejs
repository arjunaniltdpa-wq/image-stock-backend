/* INFINITE SCROLL */
/* ---------------------------------- */
let relatedScrollLock = false;

window.addEventListener("scroll", async () => {

  if (relatedScrollLock) return;

  if (
    window.innerHeight + window.scrollY
    >= document.body.offsetHeight - 1200
  ) {

    relatedScrollLock = true;

    const keyword =
    relatedKeywordList[
      relatedKeywordIndex - 1
    ];

    if (!keyword) {
      relatedScrollLock = false;
      return;
    }

    const loaded =
    await loadMoreRelated(keyword);

    if (!loaded) {
      await loadNextKeywordBatch();
    }

    setTimeout(() => {
      relatedScrollLock = false;
    }, 700);

  }

});

