<script>
/* ---------------------------------- */
/* GLOBAL SETTINGS */
/* ---------------------------------- */
const API_BASE = "https://api.pixeora.com";

/* ---------------------------------- */
/* SUBJECT DETECTION */
/* ---------------------------------- */
function detectMainSubject(title) {
  if (!title) return "";
  const t = title.toLowerCase();

  const map = [
    ["tiger","tiger"],["lion","lion"],["cat","cat"],["dog","dog"],
    ["elephant","elephant"],["wolf","wolf"],["bear","bear"],["horse","horse"],
    ["bird","bird"],["duck","bird"],["eagle","bird"],["sparrow","bird"],["parrot","bird"],
    ["fish","fish"],["ocean","fish"],["underwater","fish"],["sea","fish"],["coral","fish"],
    ["bridge","bridge"],["building","architecture"],["architecture","architecture"],["city","architecture"],
    ["mountain","mountain"],["river","river"],["lake","lake"],["waterfall","waterfall"],["forest","forest"],
    ["girl","portrait"],["woman","portrait"],["man","portrait"],["kid","portrait"],["face","portrait"],["people","portrait"],
  ];

  for (let [word, subject] of map) {
    if (t.includes(word)) return subject;
  }
  return "";
}

/* ---------------------------------- */
/* UNIVERSAL ID + SLUG (FINAL FIX) */
/* ---------------------------------- */

let rawSlug = "";

// 1️⃣ Priority: clean /photo/slug-ID URL
if (window.location.pathname.startsWith("/photo/")) {
  rawSlug = window.location.pathname.replace("/photo/", "").trim();
}

// 2️⃣ Fallback: ?slug=slug-ID (old links, bots, download.html)
if (!rawSlug) {
  const params = new URLSearchParams(window.location.search);
  rawSlug = params.get("slug") || "";
}

if (!rawSlug) {
  console.error("No slug found in URL");
}

// Extract Mongo ID if present
const idMatch = rawSlug.match(/([a-f0-9]{24})$/i);
const imageId = idMatch ? idMatch[1] : null;

// Clean slug (optional fallback usage)
let slug = rawSlug
  .replace(/-[a-f0-9]{24}$/i, "")
  .replace(/-pixeora$/i, "");

/* ---------------------------------- */
/* FORCE CLEAN CANONICAL URL */
/* ---------------------------------- */

// If page opened via download.html?slug=...
if (
  rawSlug &&
  !window.location.pathname.startsWith("/photo/")
) {
  window.history.replaceState(
    null,
    "",
    `/photo/${rawSlug}`
  );
}

/* ---------------------------------- */
/* DOWNLOAD HELPER — FORCED DOWNLOAD */
/* ---------------------------------- */
async function downloadImage(rawName) {
  const file = encodeURIComponent(rawName);
  const apiURL = `${API_BASE}/api/images/download/${file}`;

  // Non-blocking tracking
  try {
    navigator.sendBeacon
      ? navigator.sendBeacon(`${API_BASE}/api/images/track-download/${file}`)
      : fetch(`${API_BASE}/api/images/track-download/${file}`, { method: "POST" });
  } catch (e) {}

  // Force download using backend (works on all devices)
  window.location.href = apiURL;
}

async function loadImageDetails() {
  try {
    let apiList = [];

    // ✅ FIX: always send FULL slug-id (backend expects this)
    if (rawSlug) {
      apiList.push(`${API_BASE}/api/images/slug/${rawSlug}`);
    }

    let img = null;

    for (let url of apiList) {
      const res = await fetch(url);
      if (!res.ok) continue;

      const j = await res.json();
      img = j.image || j.data || j.result || j;

      if (Array.isArray(img)) img = img[0];
      if (!img || typeof img !== "object") {
        throw new Error("Invalid image data");
      }        
      if (img && (img._id || img.fileName)) break;
    }

    // Normalize ID
    if (!img._id && img.id) img._id = img.id;

    // CDN URLs
    const file = encodeURIComponent(img.fileName || img.file || "");
    const thumbUrl = img.thumbnailFileName
      ? `https://cdn.pixeora.com/${encodeURIComponent(img.thumbnailFileName)}`
      : (file ? `https://cdn.pixeora.com/thumbs/${file}` : "");

    const previewUrl = img.previewFileName
    ? `https://cdn.pixeora.com/${encodeURIComponent(img.previewFileName)}`
    : img.fileName
        ? `https://cdn.pixeora.com/${encodeURIComponent(img.fileName)}`
        : "";

    const originalUrl = file
      ? `https://cdn.pixeora.com/${file}`
      : (img.url || "");    

    const linkImg = document.createElement("link");
    linkImg.rel = "image_src";
    linkImg.href = previewUrl || originalUrl;
    document.head.appendChild(linkImg);

    const mainImg = document.getElementById("download-image");

    const skeleton = document.getElementById("main-skeleton");
    if (mainImg.complete) {
      skeleton.style.display = "none";
      mainImg.style.visibility = "visible";
      mainImg.style.opacity = "1";
    }

    // --- 1️⃣ Show thumbnail immediately (FAST) ---
    if (thumbUrl) {
      mainImg.src = thumbUrl;
      mainImg.style.filter = "blur(6px)";
      mainImg.style.visibility = "visible"; // 👈 ADD
      skeleton.style.display = "none";
    }

    // --- 2️⃣ Upgrade ONLY to preview.webp ---
    // --- 2️⃣ Decide FINAL image (preview > original) ---
    const finalMainSrc = previewUrl || originalUrl;

    if (finalMainSrc) {
      const finalImg = new Image();
      finalImg.src = finalMainSrc;  

      finalImg.onload = () => {
        mainImg.src = finalMainSrc;
        mainImg.style.transition = "filter .4s ease, opacity .3s ease";
        mainImg.style.filter = "blur(0)"; 
        mainImg.style.opacity = "1";
        mainImg.style.visibility = "visible"; // 👈 ADD

        skeleton.style.opacity = "0";

        setTimeout(() => {
          skeleton.style.display = "none";
        }, 400);

        if (finalImg.naturalWidth && finalImg.naturalHeight) {
          mainImg.style.aspectRatio =
            `${finalImg.naturalWidth}/${finalImg.naturalHeight}`;

          if (typeof ld !== "undefined") {
            ld.width = finalImg.naturalWidth;
            ld.height = finalImg.naturalHeight;

            if (ldEl) ldEl.textContent = JSON.stringify(ld);
          }
        }
      };
    }
    // Title
    const safeTitle =
      img.title?.trim() ||
      img.fileName?.trim() ||
      img.slug?.trim() ||
      "Untitled Image";
    mainImg.alt = safeTitle;

    // Download
    const downloadAnchor = document.getElementById("download-link");

    if (downloadAnchor && file) {

      downloadAnchor.onclick = (e) => {

        e.preventDefault();

        downloadImage(
          img.fileName || img.file || ""
        );

      };

    }
    window.__originalFileName = img.fileName || img.file || "";
    window.__imageFileSize = img.size || null;

    // Create schema FIRST
    const ld = {
      "@context": "https://schema.org",
      "@type": "ImageObject",

      "name": safeTitle,
      "description": img.description || safeTitle,

      "contentUrl": originalUrl || previewUrl,
      "thumbnailUrl": thumbUrl,

      "url": window.location.href,
      "representativeOfPage": true,

      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": window.location.href
      },

      "creator": {
        "@type": "Organization",
        "name": "Pixeora",
        "url": "https://pixeora.com"
      },

      "creditText": "Pixeora Photo",
      "license": "https://pixeora.com/license",
      "acquireLicensePage": "https://pixeora.com/license"
    };

    const breadcrumbSchema = {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://pixeora.com"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Stock Images",
          "item": "https://pixeora.com"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": safeTitle,
          "item": window.location.href
        }
      ]
    };

    const breadcrumbScript = document.createElement("script");
    breadcrumbScript.type = "application/ld+json";
    breadcrumbScript.textContent = JSON.stringify(breadcrumbSchema);
    document.head.appendChild(breadcrumbScript);

    const ldEl = document.getElementById("ld-json");
    if (ldEl) ldEl.textContent = JSON.stringify(ld);

    // 👉 Load ORIGINAL image only for dimension accuracy
    if (originalUrl) {
      const dimImg = new Image();
      dimImg.src = originalUrl;

      dimImg.onload = () => {
        if (dimImg.naturalWidth && dimImg.naturalHeight) {
          ld.width = dimImg.naturalWidth;
          ld.height = dimImg.naturalHeight;

          if (ldEl) ldEl.textContent = JSON.stringify(ld);
        }
      };
    }

    // Keywords
    const keywords =
      (img.keywords?.length ? img.keywords :
      img.tags?.length ? img.tags : []).slice(0, 5); // ✅ LIMIT

    // Related
    const subject = detectMainSubject(img.title || img.fileName || "");

    startRelatedSystem(
      [subject, ...keywords.slice(0,3)].filter(Boolean),
      img   // 🔥 THIS IS THE IMPORTANT PART
    );

  } catch (err) {
    console.error("Loader Error:", err);
    document.querySelector("h1").textContent = "Image Not Found.";
  }
}

