/* ---------------------------------- */
/* FORCE SLUG → SLUG-ID REDIRECT */
/* ---------------------------------- */
async function ensureCanonicalSlug() {
  if (!rawSlug) return false;

  if (/[a-f0-9]{24}$/i.test(rawSlug)) {
    return false; // already canonical
  }

  try {
    const res = await fetch(
      `${API_BASE}/api/images/resolve-slug/${encodeURIComponent(rawSlug)}`
    );

    if (!res.ok) return false;

    const data = await res.json();
    if (!data?.slug) return false;

    window.location.replace(`/photo/${data.slug}`);
    return true; // redirect triggered
  } catch {
    return false;
  }
}

/* ---------------------------------- */
/* COOKIE + IMAGE LOAD + SEARCH — SINGLE CLEAN DOM READY */
/* ---------------------------------- */
document.addEventListener("DOMContentLoaded", function () {

  /* SEARCH FORM */
  const form = document.getElementById("searchForm");
  if (form) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const q = document.getElementById("searchInput").value.trim();
      if (q.length > 0) {
        window.location.href = `/search.html?query=${encodeURIComponent(q)}`;
      }
    });
  }

  /* ENSURE CANONICAL SLUG FIRST */
  ensureCanonicalSlug();

  /* COOKIE BANNER */
  const banner = document.getElementById("cookie-banner");
  const acceptBtn = document.getElementById("cookie-accept");

  if (banner && !localStorage.getItem("cookieConsent")) {

    setTimeout(() => {

      banner.classList.add("show");

    }, 500);

  }

  if (acceptBtn && banner) {

    acceptBtn.addEventListener("click", () => {

      localStorage.setItem("cookieConsent", "true");

      banner.classList.remove("show");

    });

  }
    /* TOUCH PROTECTION */

  const protectOverlay = document.getElementById("image-protect-overlay");

  if (protectOverlay) {

    let moved = false;

    protectOverlay.addEventListener("touchstart", () => {
      moved = false;
    }, { passive: true });

    protectOverlay.addEventListener("touchmove", () => {
      moved = true;
    }, { passive: true });

    protectOverlay.addEventListener("touchend", (e) => {
      if (!moved) e.preventDefault();
    }, { passive: false });

  }
  
});

function handleAdsVisibility() {

  // Hide ads if running locally
  if (location.protocol === 'file:') {
    document.querySelectorAll(
      '.ad-section, .ad-item, .banner-ad, .side-ad-vertical, .bottom-sticky-ad'
    ).forEach(ad => ad.style.display = 'none');
    return;
  }

  document.querySelectorAll('ins.adsbygoogle').forEach(ins => {

    const container = ins.closest(
      '.ad-section, .ad-item, .banner-ad, .side-ad-vertical, .bottom-sticky-ad'
    );

    setTimeout(() => {
      if (!ins.querySelector("iframe")) {
        if (container) container.style.display = 'none';
      }
    }, 2500);

  });
}

// Run after page load
window.addEventListener("load", handleAdsVisibility);

// Re-check after every ad push
const originalPush = (window.adsbygoogle = window.adsbygoogle || []).push;
window.adsbygoogle.push = function () {
  originalPush.apply(this, arguments);
  setTimeout(handleAdsVisibility, 2500);
};

/* 🔥 SCROLL-AWARE LEGAL BAR */
let lastScrollTop = 0;
const legalBar = document.getElementById("legalBar");
let ticking = false;

if (legalBar) {

  window.addEventListener("scroll", () => {

    if (!ticking) {

      window.requestAnimationFrame(() => {

        const scrollTop =
          window.pageYOffset ||
          document.documentElement.scrollTop;

        // show at top
        if (scrollTop < 100) {

          legalBar.classList.remove("hidden");

        }
        // scrolling down
        else if (scrollTop > lastScrollTop) {

          legalBar.classList.add("hidden");

        }
        // scrolling up
        else {

          legalBar.classList.remove("hidden");

        }

        lastScrollTop =
          scrollTop <= 0 ? 0 : scrollTop;

        ticking = false;

      });

      ticking = true;

    }

  });

}

